{
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "\"$PLUGIN_ROOT/scripts/hooks/ospec-hooks\" session-start",
            "commandWindows": "\"%PLUGIN_ROOT%\\scripts\\hooks\\ospec-hooks\" session-start",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "\"$PLUGIN_ROOT/scripts/hooks/ospec-hooks\" pre-tool-use",
            "commandWindows": "\"%PLUGIN_ROOT%\\scripts\\hooks\\ospec-hooks\" pre-tool-use",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
