{
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "OSPEC_TARGET=codex OSPEC_CODEX_WRAPPER=1 \"__OSPEC_RUNTIME__/scripts/hooks/ospec-hooks\" session-start",
            "commandWindows": "set OSPEC_TARGET=codex&& set OSPEC_CODEX_WRAPPER=1&& \"__OSPEC_RUNTIME__\\scripts\\hooks\\ospec-hooks\" session-start",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "OSPEC_TARGET=codex OSPEC_CODEX_WRAPPER=1 \"__OSPEC_RUNTIME__/scripts/hooks/ospec-hooks\" pre-tool-use",
            "commandWindows": "set OSPEC_TARGET=codex&& set OSPEC_CODEX_WRAPPER=1&& \"__OSPEC_RUNTIME__\\scripts\\hooks\\ospec-hooks\" pre-tool-use",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
