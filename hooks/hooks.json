{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "node \"${PLUGIN_ROOT}/scripts/hooks/session-start.js\""
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "node \"${PLUGIN_ROOT}/scripts/hooks/pre-tool-use.js\"",
        "timeoutSec": 5
      }
    ],
    "PreCompact": [
      {
        "type": "command",
        "command": "node \"${PLUGIN_ROOT}/scripts/hooks/pre-compact.js\"",
        "timeoutSec": 5
      }
    ],
    "SubagentStop": [
      {
        "type": "command",
        "command": "node \"${PLUGIN_ROOT}/scripts/hooks/subagent-stop.js\"",
        "timeoutSec": 5
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "node \"${PLUGIN_ROOT}/scripts/hooks/stop.js\"",
        "timeoutSec": 5
      }
    ]
  }
}
